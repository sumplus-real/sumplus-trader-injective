# Copy to .deploy.env and fill in DEPLOYER_*. .deploy.env is gitignored.
# Injective native EVM TESTNET — values below VERIFIED 2026-06-25 (live indexer + RPC).

ETH_URL=https://k8s.testnet.json-rpc.injective.network/
CHAIN_ID=1439                       # EVM testnet (mainnet = 1776). eth_chainId returns 0x59f.
GAS_LIMIT=10000000
GAS_PRICE=160000000

# Deployer = the trading EOA. Foundry keystore account name + password, OR use --private-key.
DEPLOYER_ACCOUNT=inj-testnet
DEPLOYER_PWD=

# Subaccount index used for the contract's trading subaccount (matches backend INJ_SUBACCOUNT_INDEX).
SUBACCOUNT_INDEX=1

# Quote denom + first deposit (CHAIN FORMAT: testnet USDT = 6 decimals -> 50 USDT = 50000000).
# NOTE: testnet USDT denom differs from mainnet (peggy0xdAC17...).
QUOTE_DENOM=peggy0x87aB3B4C8661e07D6372361211B96ed4Dc36B1B5
DEPOSIT_AMOUNT=50000000

# Helix INJ/USDT spot market id (TESTNET). Base = inj (18d), quote = USDT (6d).
SPOT_MARKET_INJ_USDT=0x0611780ba69656949525013d947713300f56c37b6175e02f26bffa495c3208fe
